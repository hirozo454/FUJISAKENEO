# ============================================================
# FUJI-SAKE-PREMIUM 環境変数テンプレート
# ------------------------------------------------------------
# このファイルをコピーして `.env.local` を作成してください:
#   cp .env.example .env.local
#
# `.env*` は .gitignore 済みのため、実値は GitHub に push されません。
# ============================================================

# --- GitHub / Git 認証 ---
GITHUB_TOKEN=
GITHUB_USERNAME=

# --- Vercel ---
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# --- データベース / API ---
DATABASE_URL=
API_KEY=
API_SECRET=

# --- 認証系 ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- その他のパスワード・機密情報 ---
ADMIN_PASSWORD=
SMTP_PASSWORD=
